{
  "$schema": "https://schemas.wp.org/wp/6.8/theme.json",
  "version": 3,
  "settings": {
    "appearanceTools": true,
    "color": {
      "defaultDuotone": false,
      "defaultGradients": false,
      "defaultPalette": false,
      "palette": [
        {
          "color": "#001D8F",
          "name": "Azul Ardeso",
          "slug": "ardeso-blue"
        },
        {
          "color": "#172857",
          "name": "Azul noche",
          "slug": "ardeso-navy"
        },
        {
          "color": "#D00086",
          "name": "Magenta Ardeso",
          "slug": "ardeso-pink"
        },
        {
          "color": "#8C99BD",
          "name": "Linea",
          "slug": "ardeso-line"
        },
        {
          "color": "#F5F8FC",
          "name": "Fondo suave",
          "slug": "ardeso-soft"
        },
        {
          "color": "#FFFFFF",
          "name": "Blanco",
          "slug": "white"
        }
      ]
    },
    "layout": {
      "contentSize": "1120px",
      "wideSize": "1480px"
    },
    "spacing": {
      "defaultSpacingSizes": false,
      "spacingSizes": [
        {
          "name": "Small",
          "size": "20px",
          "slug": "30"
        },
        {
          "name": "Medium",
          "size": "clamp(30px, 5vw, 56px)",
          "slug": "50"
        },
        {
          "name": "Large",
          "size": "clamp(48px, 7vw, 86px)",
          "slug": "70"
        }
      ],
      "units": ["%", "px", "em", "rem", "vh", "vw"]
    },
    "typography": {
      "defaultFontSizes": false,
      "fluid": true,
      "fontFamilies": [
        {
          "fontFamily": "Montserrat, Arial, sans-serif",
          "name": "Montserrat",
          "slug": "montserrat"
        }
      ],
      "fontSizes": [
        {
          "fluid": {
            "min": "14px",
            "max": "16px"
          },
          "name": "Small",
          "size": "clamp(14px, 0.85rem + 0.2vw, 16px)",
          "slug": "small"
        },
        {
          "fluid": {
            "min": "16px",
            "max": "19px"
          },
          "name": "Regular",
          "size": "clamp(16px, 0.95rem + 0.3vw, 19px)",
          "slug": "regular"
        },
        {
          "fluid": {
            "min": "24px",
            "max": "42px"
          },
          "name": "Heading",
          "size": "clamp(24px, 1.2rem + 1.8vw, 42px)",
          "slug": "heading"
        },
        {
          "fluid": {
            "min": "42px",
            "max": "92px"
          },
          "name": "Display",
          "size": "clamp(42px, 2rem + 4vw, 92px)",
          "slug": "display"
        }
      ]
    },
    "custom": {
      "ardeso": {
        "logo": "assets/images/logo-ardeso.svg"
      }
    }
  },
  "styles": {
    "color": {
      "background": "#FFFFFF",
      "text": "#172857"
    },
    "typography": {
      "fontFamily": "var:preset|font-family|montserrat",
      "fontSize": "var:preset|font-size|regular",
      "lineHeight": "1.45"
    },
    "elements": {
      "button": {
        "border": {
          "radius": "7px"
        },
        "color": {
          "background": "#D00086",
          "text": "#FFFFFF"
        },
        "typography": {
          "fontWeight": "800"
        }
      },
      "heading": {
        "color": {
          "text": "#001D8F"
        },
        "typography": {
          "fontWeight": "700",
          "lineHeight": "1.12"
        }
      }
    }
  },
  "customTemplates": [
    {
      "name": "page-nosotros",
      "postTypes": ["page"],
      "title": "Ardeso Nosotros"
    },
    {
      "name": "page-servicios",
      "postTypes": ["page"],
      "title": "Ardeso Servicios"
    },
    {
      "name": "page-nuestro-trabajo",
      "postTypes": ["page"],
      "title": "Ardeso Nuestro Trabajo"
    },
    {
      "name": "page-contacto",
      "postTypes": ["page"],
      "title": "Ardeso Contacto"
    }
  ],
  "templateParts": [
    {
      "area": "header",
      "name": "header",
      "title": "Header"
    },
    {
      "area": "footer",
      "name": "footer",
      "title": "Footer"
    }
  ]
}
